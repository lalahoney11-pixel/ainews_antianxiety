{
  "$schema": "https://zeabur.com/schema.json",
  "name": "ai-video-generator",
  "services": [
    {
      "name": "ai-video-generator-web",
      "src": "./",
      "type": "static",
      "staticOutputDir": "./",
      "headers": [
        {
          "source": "**/*",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=0, must-revalidate"
            }
          ]
        },
        {
          "source": "*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=0, must-revalidate"
            }
          ]
        }
      ]
    }
  ]
}
